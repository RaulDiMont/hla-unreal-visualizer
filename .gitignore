
#################################
# Unreal Engine Generated Files #
#################################
/Binaries
/Build
/DerivedDataCache
/Intermediate
/Saved
/Content/Fab

# UBT-generated Visual Studio project files
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.sln

# Third-party UBT output (generated by Unreal Build Tool, not source-controlled)
ThirdParty/*/Binaries/
# Note: lib/ and bin/ are intentionally tracked so the project builds and runs after a fresh clone.
# OpenRTI binaries are LGPL — source available at https://github.com/onox/OpenRTI

# Cesium for Unreal and other Marketplace plugins
# These are installed locally from the Epic Launcher and are not part of the repo
Plugins/

# Cesium ion server config — contains the personal API access token, must not be public
Content/CesiumSettings/

# CPP cache and database files
*.VC.db
*.opendb
*.opensdf
*.sdf

#################################
# IDEs                          #
#################################
/.vs/
.vscode/
.idea/

# User-specific IDE files
*.suo
*.user
*.rsuser
*.userosscache
*.sln.docstates

#################################
# OS                            #
#################################
.DS_Store
._*
Thumbs.db
ehthumbs.db

#################################
# Miscellaneous                 #
#################################
*.orig
*.tmp
*_BackUpThisFolder_*
/cesium-request-cache.sqlite
/cesium-request-cache.sqlite-shm
/cesium-request-cache.sqlite-wal
