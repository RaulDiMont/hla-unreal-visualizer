
#################################
# Unreal Engine Generated Files #
#################################
/Binaries
/Build
/DerivedDataCache
/Intermediate
/Saved
/Content/Fab

# UBT-generated Visual Studio project files
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.sln

# Third-party compiled binaries (e.g. OpenRTI for Windows)
# Headers and source can be tracked; compiled output should not
ThirdParty/*/Binaries/
ThirdParty/*/lib/
ThirdParty/*/bin/
# But keep the placeholder files that track the directories in git
!ThirdParty/**/.gitkeep

# Cesium for Unreal and other Marketplace plugins
# These are installed locally from the Epic Launcher and are not part of the repo
Plugins/

# CPP cache and database files
*.VC.db
*.opendb
*.opensdf
*.sdf

#################################
# IDEs                          #
#################################
/.vs/
.vscode/
.idea/

# User-specific IDE files
*.suo
*.user
*.rsuser
*.userosscache
*.sln.docstates

#################################
# OS                            #
#################################
.DS_Store
._*
Thumbs.db
ehthumbs.db

#################################
# Miscellaneous                 #
#################################
*.orig
*.tmp
*_BackUpThisFolder_*
/cesium-request-cache.sqlite
/cesium-request-cache.sqlite-shm
/cesium-request-cache.sqlite-wal
